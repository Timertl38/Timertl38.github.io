// ================= COLLISION =================
function collidesWithObstacle(x,y,r) {
  for(let o of obstacles) if(x+r>o.x && x-r<o.x+o.w && y+r>o.y && y-r<o.y+o.h) return true;
  return false;
}

// ================= ENEMY AI =================
function moveEnemies() {
  enemies.forEach(e=>{
    if(e.type==="normal" || e.type==="fast"){
      let dx=ball.x-e.x; let dy=ball.y-e.y; let dist=Math.hypot(dx,dy); if(dist===0) return; dx/=dist; dy/=dist;
      let newX=e.x+dx*e.speed; let newY=e.y+dy*e.speed;
      if(!collidesWithObstacle(newX,newY,e.radius)){ e.x=newX; e.y=newY; }
      else { let tryX=e.x+dx*e.speed; if(!collidesWithObstacle(tryX,e.y,e.radius)) e.x=tryX;
             let tryY=e.y+dy*e.speed; if(!collidesWithObstacle(e.x,tryY,e.radius)) e.y=tryY; }
    } else if(e.type==="shooter"){
      if(Date.now()-e.lastShot>=e.shootInterval){
        let dx=ball.x-e.x; let dy=ball.y-e.y; let dist=Math.hypot(dx,dy); dx/=dist; dy/=dist;
        bullets.push({x:e.x,y:e.y,dx:dx*4,dy:dy*4,radius:5}); e.lastShot=Date.now();
      }
    }
  });
}

// ================= BULLETS MOVEMENT =================
function moveBullets(){
  bullets.forEach((b,i)=>{
    b.x+=b.dx; b.y+=b.dy;
    if(b.x<0 || b.x>W || b.y<0 || b.y>H) bullets.splice(i,1);
    if(!shieldActive && Math.hypot(ball.x-b.x, ball.y-b.y)<ball.radius+b.radius){ endMessage="SHOT!"; createEndMenu(false); gameState="end"; }
  });
}

// ================= PLAYER COLLISION =================
function checkObstacleCollision(){
  if(collidesWithObstacle(ball.x,ball.y,ball.radius)){
    if(keys["ArrowUp"]) ball.y+=ball.speed;
    if(keys["ArrowDown"]) ball.y-=ball.speed;
    if(keys["ArrowLeft"]) ball.x+=ball.speed;
    if(keys["ArrowRight"]) ball.x-=ball.speed;
  }
}

function checkEnemyCollision(){
  if(shieldActive) return;
  for(let e of enemies){
    if(e.type==="normal" || e.type==="fast"){
      if(Math.hypot(ball.x-e.x, ball.y-e.y)<ball.radius+e.radius){ endMessage="CAUGHT!"; createEndMenu(false); gameState="end"; }
    }
  }
}

// ================= PLAYER MOVEMENT =================
let keys={};
window.addEventListener("keydown", e=>keys[e.key]=true);
window.addEventListener("keyup", e=>keys[e.key]=false);
window.addEventListener("keydown", e=>{ if(e.code==="Space") startDash(); });

function moveBall(){
  let moveX=0, moveY=0;
  if(keys["ArrowUp"]) moveY-=ball.speed;
  if(keys["ArrowDown"]) moveY+=ball.speed;
  if(keys["ArrowLeft"]) moveX-=ball.speed;
  if(keys["ArrowRight"]) moveX+=ball.speed;
  if(isDashing){ moveX*=3; moveY*=3; dashTrail.push({x:ball.x,y:ball.y,alpha:1}); }
  ball.x+=moveX; ball.y+=moveY;
  ball.x=Math.max(ball.radius,Math.min(W-ball.radius,ball.x));
  ball.y=Math.max(ball.radius,Math.min(H-ball.radius,ball.y));
}

// ================= BOSS FUNCTIONS =================
function moveBoss(){
  if(!boss) return;
  let dx = ball.x - boss.x;
  let dy = ball.y - boss.y;
  let dist = Math.hypot(dx,dy);
  if(dist===0) return;
  dx/=dist; dy/=dist;
  boss.x+=dx*boss.speed;
  boss.y+=dy*boss.speed;

  // Boss schiet naar speler
  if(Date.now()-boss.lastShot>=boss.shootInterval){
    let dx = ball.x - boss.x;
    let dy = ball.y - boss.y;
    let baseAngle = Math.atan2(dy, dx);
    let spread = 0.2;
    for(let i=-1; i<=1; i++){
      let angle = baseAngle + i * spread;
      bullets.push({ x: boss.x, y: boss.y, dx: Math.cos(angle)*4, dy: Math.sin(angle)*4, radius: 5 });
    }
    boss.lastShot = Date.now();
  }
}

function drawBoss(){
  if(!boss) return;
  const gradient = ctx.createRadialGradient(boss.x-3,boss.y-3,boss.radius*0.2,boss.x,boss.y,boss.radius);
  gradient.addColorStop(0,"#e0b3ff"); // highlight
  gradient.addColorStop(1,"purple");
  ctx.beginPath();
  ctx.arc(boss.x,boss.y,boss.radius,0,Math.PI*2);
  ctx.fillStyle = gradient;
  ctx.shadowColor = "rgba(0,0,0,0.5)";
  ctx.shadowBlur = 10;
  ctx.fill();
  ctx.shadowBlur = 0;
}

function drawBossDrops(){
  bossDrops.forEach(d=>{
    if(!d.collected){
      ctx.beginPath();
      ctx.arc(d.x,d.y,d.radius,0,Math.PI*2); ctx.fillStyle="purple"; ctx.fill();
      ctx.lineWidth=2; ctx.strokeStyle="white"; ctx.stroke();
    }
  });
}

// ================= BOSS HEALTH =================
function drawBossHealthBar(){
  if(!boss) return;
  const barWidth = 60;
  const barHeight = 8;
  const x = boss.x - barWidth/2;
  const y = boss.y - boss.radius - 15;
  ctx.fillStyle = "gray";
  ctx.fillRect(x, y, barWidth, barHeight);
  const healthWidth = (boss.health / boss.maxHealth) * barWidth;
  ctx.fillStyle = "red";
  ctx.fillRect(x, y, healthWidth, barHeight);
  ctx.strokeStyle = "black";
  ctx.lineWidth = 2;
  ctx.strokeRect(x, y, barWidth, barHeight);
}

function checkBossDrops(){
  bossDrops.forEach(d=>{
    if(!d.collected && Math.hypot(ball.x-d.x,ball.y-d.y)<ball.radius+d.radius){
      d.collected = true;

      // Boss health verlagen
      if(boss){
        boss.health--;
        if(boss.health <= 0){
          boss = null;
          endMessage="LEVEL COMPLETE!";
          createEndMenu(true);
        }
      }
    }
  });
}

