// ================= DASH SYSTEM =================
const maxDashes = 3;
let dashSlots = [
  { ready: true, cooldown: 2000, lastUsed: 0 },
  { ready: true, cooldown: 2000, lastUsed: 0 },
  { ready: true, cooldown: 2000, lastUsed: 0 }
];
let dashDuration = 150;
let isDashing = false;
let dashStartTime = 0;
let currentDashIndex = null;
let dashTrail = [];

function startDash() {
  for (let i = 0; i < dashSlots.length; i++) {
    if (dashSlots[i].ready) {
      dashSlots[i].ready = false;
      dashSlots[i].lastUsed = Date.now();
      isDashing = true;
      dashStartTime = Date.now();
      currentDashIndex = i;
      break;
    }
  }
}

function updateDash() {
  if (isDashing && Date.now() - dashStartTime >= dashDuration) {
    isDashing = false;
    currentDashIndex = null;
  }
  dashSlots.forEach(d => {
    if (!d.ready && Date.now() - d.lastUsed >= d.cooldown) d.ready = true;
  });
}

// ================= POWER-UPS =================
let powerUps = [];
let inventory = [];
let activePowerUp = null;
let powerUpTimer = 0;
const powerUpDuration = 5000;
const magnetRadius = 100;
let shieldActive = false;

function spawnPowerUps() {
  powerUps = [
    { type: "magnet", x: Math.random()*(W-40)+20, y: Math.random()*(H-40)+20, radius: 12, active: false },
    { type: "shield", x: Math.random()*(W-40)+20, y: Math.random()*(H-40)+20, radius: 12, active: false }
  ];
}

function checkPowerUpPickup() {
  powerUps.forEach(p => {
    if (!p.active && Math.hypot(ball.x - p.x, ball.y - p.y) < ball.radius + p.radius) {
      inventory.push(p.type);
      p.active = true;
    }
  });
}

window.addEventListener("keydown", e => {
  if (e.key === "Control" && !activePowerUp && inventory.length > 0) {
    activePowerUp = inventory.shift();
    powerUpTimer = Date.now();
    if (activePowerUp === "shield") shieldActive = true;
  }
});

function updatePowerUps(){
  if(activePowerUp){
    let elapsed = Date.now() - powerUpTimer;
    if(elapsed >= powerUpDuration){
      activePowerUp = null;
      shieldActive = false;
    } else if(activePowerUp==="magnet"){
      coins.forEach(c=>{
        let dx = ball.x - c.x;
        let dy = ball.y - c.y;
        let dist = Math.hypot(dx,dy);
        if(dist < magnetRadius){ c.x += dx*0.05; c.y += dy*0.05; }
      });
    }
  }
}

// ================= POWER-UP VISUAL EFFECTS =================
function drawActivePowerUpEffects() {
    if (!activePowerUp) return;

    if (activePowerUp === "magnet") {
        ctx.beginPath();
        ctx.arc(ball.x, ball.y, ball.radius + 20, 0, Math.PI * 2);
        ctx.fillStyle = "rgba(0,255,255,0.2)";
        ctx.fill();
    } else if (activePowerUp === "shield") {
        let pulse = Math.sin((Date.now() - powerUpTimer) / 100) * 5;
        ctx.beginPath();
        ctx.arc(ball.x, ball.y, ball.radius + 10 + pulse, 0, Math.PI * 2);
        ctx.strokeStyle = "lime";
        ctx.lineWidth = 4;
        ctx.stroke();
    }
}

// ================= HIGHSCORE =================
function getHighscore() { return parseInt(localStorage.getItem("highscore_" + difficulty)) || 0; }
function setHighscore(value) { localStorage.setItem("highscore_" + difficulty, value); }

// ================= DIFFICULTY =================
function applyDifficultySettings() {
  if (difficulty === "easy") { ball.speed = 4; baseTime = 15; }
  if (difficulty === "medium") { ball.speed = 5; baseTime = 12; }
  if (difficulty === "hard") { ball.speed = 6; baseTime = 10; }
}

// ================= LEVEL SCALING =================
function applyLevelScaling() {
  totalCoins = 4 + level * 2;
  let difficultyBonus = difficulty === "easy" ? 5 : difficulty === "medium" ? 3 : 0;
  countdownTime = Math.max(5, baseTime - level * 0.7 + difficultyBonus + level);
  createObstacles(level + 1);
  spawnPowerUps();

  const levelColors = ["#1b3a2d", "#f4e2a1", "#8b5a2b"];
  bgColor = levelColors[(level-1) % 3];

  if(level % 3 === 0){
    spawnBoss();
  } else {
    createEnemies(level);
    boss = null;
  }
}

// ================= START GAME =================
let bgColor = "white";

// Boss data
let boss = null;
let bossDrops = [];

function spawnBoss(){
  boss = { 
    x: W/2, 
    y: 50, 
    radius: 25, 
    speed: 1.2, 
    shootInterval: 2000, 
    lastShot: Date.now(),
    maxHealth: 3,
    health: 3
  };
  bullets = [];
  bossDrops = [
    {x: Math.random()*(W-20)+10, y: Math.random()*(H-60)+30, radius:10, collected:false},
    {x: Math.random()*(W-20)+10, y: Math.random()*(H-60)+30, radius:10, collected:false},
    {x: Math.random()*(W-20)+10, y: Math.random()*(H-60)+30, radius:10, collected:false},
  ];
}

function startGame(resetLevel = false) {
  if (resetLevel) level = 1;
  score = 0;
  applyDifficultySettings();
  applyLevelScaling();
  coins = [];
  bullets = [];
  dashTrail = [];
  inventory = [];
  createCoins();
  ball.x = W / 2; ball.y = H / 2;
  startTime = Date.now();
  timeLeft = countdownTime;
  dashSlots.forEach(d => d.ready = true);
  isDashing = false;
  shieldActive = false;
  activePowerUp = null;
  gameState = "playing";
}

// ================= OBJECT CREATION =================
function createCoins() {
  for (let i = 0; i < totalCoins; i++) coins.push({ x: Math.random()*(W-20)+10, y: Math.random()*(H-20)+10, r: 10 });
}

function createObstacles(amount) {
  obstacles = [];
  for (let i = 0; i < amount; i++) {
    const horizontal = Math.random() < 0.5;
    if (horizontal) obstacles.push({ x: Math.random()*(W-80), y: Math.random()*(H-20), w: 80, h: 20 });
    else obstacles.push({ x: Math.random()*(W-20), y: Math.random()*(H-80), w: 20, h: 80 });
  }
}

function createEnemies(amount) {
  enemies = [];
  const corners = [ {x:20,y:20}, {x:W-20,y:20}, {x:20,y:H-20}, {x:W-20,y:H-20} ];
  for (let i = 0; i < amount; i++) {
    const typeRand = Math.random();
    const c = corners[i % 4];
    if (typeRand < 0.5) enemies.push({ x:c.x, y:c.y, radius:12, speed:1.5+level*0.3, type:"normal" });
    else if (typeRand < 0.8) enemies.push({ x:c.x, y:c.y, radius:12, speed:2+level*0.5, type:"fast" });
    else enemies.push({ x:c.x, y:c.y, radius:12, speed:1, type:"shooter", shootInterval:2000, lastShot: Date.now() });
  }
}

// ================= DRAW =================
function drawDashTrail(){
  for(let i=dashTrail.length-1; i>=0; i--){
    const t=dashTrail[i];
    ctx.beginPath();
    ctx.arc(t.x, t.y, ball.radius,0,Math.PI*2);
    ctx.fillStyle=`rgba(52,152,219,${t.alpha})`;
    ctx.fill();
    t.alpha -= 0.05;
    if(t.alpha<=0) dashTrail.splice(i,1);
  }
}

function drawBall() {
    const gradient = ctx.createRadialGradient(ball.x - 3, ball.y - 3, ball.radius*0.2, ball.x, ball.y, ball.radius);
    gradient.addColorStop(0, "#85c1e9"); // lichtblauw highlight
    gradient.addColorStop(1, "#3498db"); // standaard blauw
    ctx.beginPath();
    ctx.arc(ball.x, ball.y, ball.radius, 0, Math.PI * 2);
    ctx.fillStyle = gradient;
    ctx.shadowColor = "rgba(0,0,0,0.4)";
    ctx.shadowBlur = 8;
    ctx.fill();
    ctx.shadowBlur = 0;
}

function drawCoins() {
  coins.forEach(c=>{
    ctx.beginPath(); ctx.arc(c.x,c.y,c.r,0,Math.PI*2); ctx.fillStyle="gold"; ctx.fill();
    ctx.lineWidth=2; ctx.strokeStyle="yellow"; ctx.stroke();
  });
}

function drawObstacles() { ctx.fillStyle="#2c3e50"; obstacles.forEach(o=>ctx.fillRect(o.x,o.y,o.w,o.h)); }

function drawEnemies() {
  enemies.forEach(e => {
    ctx.beginPath();
    ctx.arc(e.x, e.y, e.radius, 0, Math.PI*2);

    let gradient;
    if(e.type==="normal"){
      gradient = ctx.createRadialGradient(e.x-2,e.y-2, e.radius*0.2, e.x, e.y, e.radius);
      gradient.addColorStop(0,"#ff6666"); // highlight
      gradient.addColorStop(1,"red");
    } else if(e.type==="fast"){
      gradient = ctx.createRadialGradient(e.x-2,e.y-2, e.radius*0.2, e.x, e.y, e.radius);
      gradient.addColorStop(0,"#ffb84d");
      gradient.addColorStop(1,"orange");
    } else if(e.type==="shooter"){
      gradient = ctx.createRadialGradient(e.x-2,e.y-2, e.radius*0.2, e.x, e.y, e.radius);
      gradient.addColorStop(0,"#d18cff");
      gradient.addColorStop(1,"purple");
    }

    ctx.fillStyle = gradient;
    ctx.shadowColor = "rgba(0,0,0,0.3)";
    ctx.shadowBlur = 6;
    ctx.fill();
    ctx.shadowBlur = 0;
  });
}
function drawBullets(){
  bullets.forEach(b=>{
    const gradient = ctx.createRadialGradient(b.x-1,b.y-1,0,b.x,b.y,b.radius);
    gradient.addColorStop(0,"#ffff99");
    gradient.addColorStop(0.5,"#ffff33");
    gradient.addColorStop(1,"black");

    ctx.beginPath();
    ctx.arc(b.x,b.y,b.radius,0,Math.PI*2);
    ctx.fillStyle = gradient;
    ctx.shadowColor = "yellow";
    ctx.shadowBlur = 6;
    ctx.fill();
    ctx.shadowBlur = 0;
  });
}

function drawPowerUps(){
  powerUps.forEach(p=>{
    if(!p.active){
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.radius, 0, Math.PI*2);
      ctx.fillStyle = p.type==="magnet"?"cyan":"lime";
      ctx.fill();
      ctx.lineWidth=2; ctx.strokeStyle="white";
      ctx.stroke();
    }
  });
}

function drawInventory(){
  ctx.fillStyle="rgba(0,0,0,0.6)";
  ctx.fillRect(W-150, H-30, 140, 25);
  ctx.fillStyle="white";
  ctx.font="14px Arial";
  ctx.fillText("Inventory: " + inventory.join(", "), W-140, H-12);
