// ================= VISUELE TOEVOEGINGEN =================

// Glans-effect voor coins
function drawCoins(){
  coins.forEach(c=>{
    ctx.beginPath();
    ctx.arc(c.x,c.y,c.r,0,Math.PI*2);
    let gradient = ctx.createRadialGradient(c.x,c.y,0,c.x,c.y,c.r);
    gradient.addColorStop(0,"#fff700");
    gradient.addColorStop(0.5,"gold");
    gradient.addColorStop(1,"orange");
    ctx.fillStyle = gradient;
    ctx.fill();
    ctx.lineWidth = 2;
    ctx.strokeStyle = "yellow";
    ctx.stroke();
  });
}

// Pulsing dash trail
function drawDashTrail(){
  for(let i=dashTrail.length-1;i>=0;i--){
    let t=dashTrail[i];
    ctx.beginPath();
    ctx.arc(t.x,t.y,ball.radius,0,Math.PI*2);
    ctx.fillStyle=`rgba(52,152,219,${t.alpha})`;
    ctx.fill();
    t.alpha -= 0.05;
    if(t.alpha<=0) dashTrail.splice(i,1);
  }
}

// Power-up visuele effecten
function drawActivePowerUpEffects(){
  if(!activePowerUp) return;

  if(activePowerUp==="magnet"){
    ctx.beginPath();
    ctx.arc(ball.x,ball.y,ball.radius+magnetRadius*0.5,0,Math.PI*2);
    ctx.fillStyle="rgba(0,255,255,0.15)";
    ctx.fill();
  }
  if(activePowerUp==="shield"){
    let pulse = Math.sin(Date.now()/100)*5;
    ctx.beginPath();
    ctx.arc(ball.x,ball.y,ball.radius+10+pulse,0,Math.PI*2);
    ctx.strokeStyle="lime";
    ctx.lineWidth=3;
    ctx.stroke();
  }
}

// Boss health bar visueel verbeteren
function drawBossHealthBar(){
  if(!boss) return;
  const barWidth = 60;
  const barHeight = 8;
  const x = boss.x - barWidth/2;
  const y = boss.y - boss.radius - 15;

  // achtergrond
  ctx.fillStyle="rgba(0,0,0,0.5)";
  ctx.fillRect(x,y,barWidth,barHeight);

  // health
  const healthWidth = (boss.health/boss.maxHealth)*barWidth;
  const gradient = ctx.createLinearGradient(x,y,x+barWidth,y);
  gradient.addColorStop(0,"red");
  gradient.addColorStop(0.5,"orange");
  gradient.addColorStop(1,"yellow");
  ctx.fillStyle = gradient;
  ctx.fillRect(x,y,healthWidth,barHeight);

  // rand
  ctx.strokeStyle="black";
  ctx.lineWidth=2;
  ctx.strokeRect(x,y,barWidth,barHeight);
}

// Boss drops pulserend effect
function drawBossDrops(){
  bossDrops.forEach(d=>{
    if(!d.collected){
      let pulse = Math.sin(Date.now()/100+d.x)*3;
      ctx.beginPath();
      ctx.arc(d.x,d.y,d.radius+pulse,0,Math.PI*2);
      ctx.fillStyle="purple";
      ctx.fill();
      ctx.lineWidth=2;
      ctx.strokeStyle="white";
      ctx.stroke();
    }
  });
}

// Bullets glow
function drawBullets(){
  bullets.forEach(b=>{
    ctx.beginPath();
    ctx.arc(b.x,b.y,b.radius,0,Math.PI*2);
    ctx.fillStyle="black";
    ctx.fill();
    ctx.shadowBlur = 6;
    ctx.shadowColor = "yellow";
    ctx.fill();
    ctx.shadowBlur = 0;
  });
}

// Obstacles met lichte gradient
function drawObstacles(){
  obstacles.forEach(o=>{
    const grad = ctx.createLinearGradient(o.x,o.y,o.x+o.w,o.y+o.h);
    grad.addColorStop(0,"#2c3e50");
    grad.addColorStop(1,"#34495e");
    ctx.fillStyle = grad;
    ctx.fillRect(o.x,o.y,o.w,o.h);
  });
}
// ================= GAME LOOP =================
function gameLoop(){
  ctx.clearRect(0,0,W,H);

  if(gameState==="start"){ drawStartScreen(); requestAnimationFrame(gameLoop); return; }
if(gameState==="instructions"){
  drawInstructionScreen();
  requestAnimationFrame(gameLoop);
  return;
}
  if(gameState==="playing"){
    ctx.fillStyle = bgColor;
    ctx.fillRect(0,0,W,H);

    timeLeft = countdownTime - (Date.now() - startTime)/1000;

    updateDash();
    updatePowerUps();
    moveBall();
    checkObstacleCollision();
    checkEnemyCollision();
    checkPowerUpPickup();

    if(boss){
      moveBoss();
      checkBossDrops();
    } else {
      moveEnemies();
    }

    moveBullets();

    drawDashTrail();
    drawBall();
    drawActivePowerUpEffects();
    drawCoins();
    drawObstacles();
    if(boss){
      drawBoss();
      drawBossDrops();
      drawBossHealthBar();
    } else {
      drawEnemies();
    }
    drawBullets();
    drawPowerUps();
    drawHUD();
    coins = coins.filter(c=>{
      if(Math.hypot(ball.x-c.x,ball.y-c.y)<ball.radius+c.r){
        score++; 
        return false; 
      }
      return true; 
    });

    if(!boss && score>=totalCoins){
      endMessage="LEVEL COMPLETE!";
      createEndMenu(true);
      gameState="end";
    }

    if(timeLeft<=0){
      endMessage="GAME OVER";
      createEndMenu(false);
      gameState="end";
    }
  }

  if(gameState==="end") drawEndScreen();

  requestAnimationFrame(gameLoop);
}

// Start the game loop
gameLoop();
