let gameState = "start"; // start | playing | end
let difficulty = "easy";
let level = 1;
let endMessage = "";

// ================= PLAYER =================
let ball = { x: W / 2, y: H / 2, radius: 15, speed: 4 };

// ================= GAME DATA =================
let coins = [];
let obstacles = [];
let enemies = [];
let bullets = [];
let score = 0;

let totalCoins = 5;
let baseTime = 15;
let countdownTime = 15;
