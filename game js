let buttons=[]; let mouse={x:0,y:0};
canvas.addEventListener("mousemove", e=>{ const rect=canvas.getBoundingClientRect(); mouse.x=e.clientX-rect.left; mouse.y=e.clientY-rect.top; });
canvas.addEventListener("click", ()=>{ buttons.forEach(b=>{ if(mouse.x>b.x && mouse.x<b.x+b.w && mouse.y>b.y && mouse.y<b.y+b.h) b.action(); }); });

function createEndMenu(win){
  buttons=[];
  if(win) buttons.push({text:"Next Level",x:W/2-100,y:H/2+10,w:200,h:40,action:()=>{level++; startGame();}});
  buttons.push({text:"Restart (Level 1)",x:W/2-100,y:H/2+60,w:200,h:40,action:()=>startGame(true)});
  buttons.push({text:"Quit",x:W/2-70,y:H/2+110,w:140,h:40,action:()=>gameState="start"});
}

